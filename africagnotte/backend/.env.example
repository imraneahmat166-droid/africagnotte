# =====================================================
# AfriCagnotte — Variables d'environnement complètes
# Copier en .env et remplir toutes les valeurs
# =====================================================

# SUPABASE
SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# CINETPAY
CINETPAY_API_KEY=VOTRE_CLE_API_CINETPAY
CINETPAY_SITE_ID=VOTRE_SITE_ID_CINETPAY
CINETPAY_SECRET_KEY=VOTRE_SECRET_KEY_CINETPAY
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2

# APP
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://africagnotte.com
BACKEND_URL=https://api.africagnotte.com

# SECURITE
JWT_SECRET=generer_avec_openssl_rand_-hex_64
WEBHOOK_SECRET=generer_avec_openssl_rand_-hex_32

# EMAIL (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@africagnotte.com
SMTP_PASS=votre_mot_de_passe_application_gmail

# SMS — Africa's Talking (recommandé pour l'Afrique)
# Créer un compte: https://africastalking.com
AT_API_KEY=VOTRE_CLE_AFRICASTALKING
AT_USERNAME=sandbox
AT_SENDER_ID=AfriCagnotte

# SMS — Twilio (alternative internationale)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE=+15005550006

# AGENTS AUTOMATISES
AGENT_CRON_ENABLED=true
AGENT_FRAUD_THRESHOLD=5
